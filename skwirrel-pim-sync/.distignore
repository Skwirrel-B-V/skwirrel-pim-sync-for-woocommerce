# Files and directories excluded from the WordPress.org SVN trunk deploy.
# Anything listed here is stripped before the 10up deploy action uploads
# the plugin folder to /trunk/ and /tags/X.Y.Z/.
#
# Paths are relative to BUILD_DIR (./skwirrel-pim-sync).

# Version control / IDE / OS
/.git
/.github
/.claude
/.idea
/.editorconfig
/.gitignore
/.DS_Store

# Distignore itself (not needed in the shipped plugin)
/.distignore

# Composer (dev only — plugin has no production composer deps)
/composer.json
/composer.lock
/vendor

# Static analysis
/phpstan.neon
/phpstan.neon.dist
/phpstan-baseline.neon
/.phpcs.xml.dist

# Tests (Pest unit + integration)
/tests
/phpunit.xml.dist
/phpunit-integration.xml.dist
/.phpunit.cache
/.pest

# wp-env (Docker dev environment)
/.wp-env.json
/.wp-env.override.json
/package.json
/package-lock.json
/node_modules

# Internal docs
/CLAUDE.md
/ASSUMPTIONS.md
/CHANGELOG.md
/PLAN.md
/README.md

# Debug/diagnostic scripts (not loaded in production)
/debug-variations.php
