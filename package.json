{
	"name": "skwirrel-wordpress",
	"version": "1.0.0",
	"private": true,
	"description": "Monorepo root – wp-env dev environment for the Skwirrel PIM sync plugin.",
	"scripts": {
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:destroy": "wp-env destroy",
		"env:clean": "wp-env clean all",
		"env:cli": "wp-env run cli wp",
		"env:logs": "wp-env logs",
		"test:unit": "wp-env run tests-cli --env-cwd=wp-content/plugins/skwirrel-pim-sync vendor/bin/pest --testsuite=Unit",
		"test:integration": "wp-env run tests-cli --env-cwd=wp-content/plugins/skwirrel-pim-sync vendor/bin/pest -c phpunit-integration.xml.dist",
		"test:all": "npm run test:unit && npm run test:integration",
		"composer:install": "wp-env run tests-cli --env-cwd=wp-content/plugins/skwirrel-pim-sync composer install",
		"composer:update": "wp-env run tests-cli --env-cwd=wp-content/plugins/skwirrel-pim-sync composer update"
	},
	"devDependencies": {
		"@wordpress/env": "^10.0.0"
	}
}
